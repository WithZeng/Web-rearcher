# === OpenAI / LLM ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# === Search ===
MAX_RESULTS=50
IEEE_API_KEY=
SCOPUS_API_KEY=

# === Full-text fetch (Unpaywall, free, highly recommended) ===
# Register at https://unpaywall.org/ -- just needs a valid email
UNPAYWALL_EMAIL=

# === Proxy (optional, supports http/https/socks5) ===
# If your institution requires a proxy to access publisher sites:
# HTTP_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=socks5://127.0.0.1:1080
HTTP_PROXY=

# === GROBID (optional, requires Docker) ===
# Docker Compose server deployment uses: http://grobid:8070
# Standalone local container: docker run --rm -d -p 8070:8070 lfoppiano/grobid:0.8.1
# Leave empty to use standard PDF parsers (pypdf/PyMuPDF)
GROBID_URL=

# === Concurrency ===
FETCH_CONCURRENCY=20
LLM_CONCURRENCY=10

# === Notion (optional) ===
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
